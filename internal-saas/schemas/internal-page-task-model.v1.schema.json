{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InternalPageTaskModelV1",
  "type": "object",
  "required": [
    "schema_version",
    "page_mode",
    "primary_user_role",
    "entities",
    "primary_tasks",
    "permissions",
    "data_density_policy",
    "state_model",
    "mobile_policy",
    "verification_contract"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"const": "internal_page_task_model.v1"},
    "page_mode": {"type": "string"},
    "primary_user_role": {"type": "string"},
    "entities": {"type": "array", "items": {"type": "object"}},
    "primary_tasks": {"type": "array", "items": {"type": "object"}},
    "permissions": {"type": "array", "items": {"type": "object"}},
    "data_density_policy": {"type": "string"},
    "state_model": {
      "type": "object",
      "required": ["empty", "loading", "error", "success"],
      "additionalProperties": true
    },
    "mobile_policy": {"type": "string"},
    "verification_contract": {"type": "array", "items": {"type": "string"}}
  }
}
