        },
        "trust_burden": {
          "$ref": "#/$defs/trust_burden"
        },
        "aesthetic_stakes": {
          "$ref": "#/$defs/aesthetic_stakes"
        },
        "functional_immediacy": {
          "$ref": "#/$defs/functional_immediacy"
        },
        "product_complexity": {
          "$ref": "#/$defs/product_complexity"
